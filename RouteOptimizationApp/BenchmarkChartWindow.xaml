<Window x:Class="RouteOptimizationApp.BenchmarkChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Benchmark графики"
        Height="520"
        Width="760"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Графично сравнение на алгоритмите"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel x:Name="ChartPanel"/>

        </ScrollViewer>

    </Grid>
</Window>
